# Server port
PORT=5000

# Set to a real MongoDB connection string to use a persistent database.
# Leave blank (or unset) to boot an in-memory MongoDB automatically — great for
# local development and demos with zero setup.
MONGO_URI=

# Example for a local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/mealplanner
# Example for MongoDB Atlas:
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/mealplanner

# JWT secret used to sign auth tokens (change in production)
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=7d

# CORS origin for the client dev server
CLIENT_ORIGIN=http://localhost:5173
