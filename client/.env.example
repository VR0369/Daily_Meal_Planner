# Optional: override the API base URL. By default the app calls "/api" which the
# Vite dev server proxies to http://localhost:5000 (see vite.config.js).
# In production, set this to your deployed API origin, e.g. https://api.example.com/api
VITE_API_URL=/api

# Optional: override the dev proxy target.
VITE_API_TARGET=http://localhost:5000
